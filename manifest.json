<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Calcula el precio de la gasolina en Ecuador según el Decreto Ejecutivo 308. Precios oficiales ARCH vigentes.">
<meta name="theme-color" content="#0f172a">
<title>Gasolina Ecuador · D.E. 308</title>
<link rel="manifest" href="manifest.json">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⛽</text></svg>">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0f172a;--bg2:#1e293b;--bg3:#334155;
  --bdr:#334155;--bdr2:#475569;
  --tx:#f1f5f9;--tx2:#94a3b8;--tx3:#64748b;
  --blue:#3b82f6;--blue-l:rgba(59,130,246,.14);
  --green:#22c55e;--green-l:rgba(34,197,94,.12);
  --red:#ef4444;--red-l:rgba(239,68,68,.12);
  --amber:#f59e0b;--amber-l:rgba(245,158,11,.12);
  --r:10px;--rs:6px
}
body{background:var(--bg);color:var(--tx);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;min-height:100vh;padding-bottom:2rem}
.wrap{max-width:580px;margin:0 auto;padding:0 14px}
.hdr{padding:1.1rem 14px .75rem;max-width:580px;margin:0 auto;display:flex;align-items:center;gap:10px}
.logo{width:38px;height:38px;background:var(--amber-l);border:.5px solid rgba(245,158,11,.3);border-radius:var(--rs);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.hdr h1{font-size:17px;font-weight:600;color:var(--tx);margin:0}
.hdr p{font-size:11px;color:var(--tx3);margin:1px 0 0}
/* Status */
.stbar{display:flex;align-items:center;gap:7px;padding:.5rem .9rem;background:var(--bg2);border-radius:var(--r);font-size:12px;color:var(--tx2);margin-bottom:.75rem}
.sdot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.live{background:var(--green);animation:pl 2s infinite}
.loading{background:var(--amber);animation:pl 1s infinite}
.cerr{background:var(--red)}
@keyframes pl{0%,100%{opacity:1}50%{opacity:.25}}
.spin{width:11px;height:11px;border:2px solid var(--bdr2);border-top-color:var(--tx2);border-radius:50%;animation:sp .7s linear infinite;display:inline-block;vertical-align:middle;margin-right:3px}
@keyframes sp{to{transform:rotate(360deg)}}
.rbtn{margin-left:auto;background:transparent;border:.5px solid var(--bdr2);border-radius:var(--rs);color:var(--tx2);font-size:11px;padding:3px 9px;cursor:pointer}
/* Banner */
.banner{display:grid;grid-template-columns:repeat(4,1fr);background:var(--bg2);border-radius:var(--r);overflow:hidden;margin-bottom:.75rem}
.bni{padding:.55rem .7rem;border-right:.5px solid var(--bdr)}
.bni:last-child{border:none}
.bnl{font-size:10px;color:var(--tx3);text-transform:uppercase;letter-spacing:.04em;margin-bottom:2px}
.bnv{font-size:13px;font-weight:600;color:var(--tx)}
/* Precio vigente */
.vigente-bar{background:var(--blue-l);border:.5px solid rgba(59,130,246,.25);border-radius:var(--rs);padding:.55rem .9rem;display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem;font-size:12px}
.vigente-lbl{color:var(--tx2)}
.vigente-per{color:var(--blue);font-weight:600}
/* Tabs */
.tabs{display:flex;gap:4px;margin-bottom:.75rem}
.tb{flex:1;padding:8px;font-size:13px;border:.5px solid var(--bdr);border-radius:var(--rs);cursor:pointer;background:transparent;color:var(--tx2);text-align:center}
.tb.on{background:var(--blue);border-color:var(--blue);color:#fff;font-weight:500}
/* Cards */
.card{background:var(--bg2);border:.5px solid var(--bdr);border-radius:var(--r);padding:.9rem;margin-bottom:.7rem}
.sec{font-size:10px;font-weight:600;color:var(--tx3);letter-spacing:.06em;text-transform:uppercase;margin-bottom:8px}
/* Fuel cards */
.frow{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-bottom:.7rem}
.fc{border:.5px solid var(--bdr);border-radius:var(--r);padding:.85rem .8rem;cursor:pointer;background:var(--bg2)}
.fc:hover{border-color:var(--bdr2)}
.fc.sel{border:1.5px solid var(--blue);background:var(--blue-l)}
.fc.nc{cursor:default}
.fn{font-size:12px;font-weight:600;color:var(--tx);margin:0 0 1px}
.fs{font-size:10px;color:var(--tx3);margin:0 0 7px}
.fp{font-size:20px;font-weight:700;color:var(--tx);margin:0;line-height:1}
.fu{font-size:10px;color:var(--tx2);margin:2px 0 0}
.badge{display:inline-block;font-size:10px;padding:2px 7px;border-radius:20px;font-weight:600;margin-top:5px}
.b-blue{background:var(--blue-l);color:var(--blue)}
.b-green{background:var(--green-l);color:var(--green)}
.b-neu{background:var(--bg3);color:var(--tx2)}
/* Mode toggle */
.mtog{display:flex;background:var(--bg2);border:.5px solid var(--bdr);border-radius:var(--rs);overflow:hidden;margin-bottom:.75rem}
.mb{flex:1;padding:9px;font-size:13px;cursor:pointer;background:transparent;border:none;color:var(--tx2);text-align:center}
.mb.on{background:var(--bg3);color:var(--tx);font-weight:500}
/* Input */
.iw{position:relative;margin-bottom:.7rem}
.iw input{width:100%;padding:12px 56px 12px 44px;font-size:20px;font-weight:600;border:.5px solid var(--bdr);border-radius:var(--rs);background:var(--bg2);color:var(--tx);-moz-appearance:textfield;outline:none}
.iw input:focus{border-color:var(--blue)}
.iw input::-webkit-inner-spin-button{-webkit-appearance:none}
.ipfx{position:absolute;left:13px;top:50%;transform:translateY(-50%);font-size:16px;color:var(--tx3);pointer-events:none}
.isfx{position:absolute;right:13px;top:50%;transform:translateY(-50%);font-size:12px;color:var(--tx3);pointer-events:none}
/* Result */
.big{font-size:44px;font-weight:700;color:var(--tx);line-height:1;margin:0 0 4px}
.rlbl{font-size:12px;color:var(--tx2)}
.sep{border:none;border-top:.5px solid var(--bdr);margin:.8rem 0}
.cr{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:.5px solid var(--bdr);font-size:13px}
.cr:last-child{border-bottom:none}
.crl{color:var(--tx2);display:flex;align-items:center;gap:6px}
.crv{font-weight:600;color:var(--tx)}
.dot{width:7px;height:7px;border-radius:50%;display:inline-block;flex-shrink:0}
.bkg{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:.7rem}
.bk{background:var(--bg3);border-radius:var(--rs);padding:.6rem .8rem}
.bkl{font-size:10px;color:var(--tx3);text-transform:uppercase;letter-spacing:.03em;margin-bottom:2px}
.bkv{font-size:14px;font-weight:600;color:var(--tx)}
/* Sim */
.sfsel{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:.75rem}
.sfc{display:flex;align-items:center;gap:7px;padding:7px 12px;border:.5px solid var(--bdr);border-radius:var(--rs);cursor:pointer;font-size:13px;color:var(--tx2);background:var(--bg2);user-select:none}
.sfc input{accent-color:var(--blue);width:14px;height:14px;cursor:pointer;flex-shrink:0}
.sfc.act{border:1.5px solid var(--blue);background:var(--blue-l);color:var(--tx);font-weight:500}
.slrow{display:flex;align-items:center;gap:10px;margin-bottom:.75rem}
.slrow label{font-size:13px;color:var(--tx2);min-width:120px;flex-shrink:0}
.slrow input[type=range]{flex:1;accent-color:var(--blue)}
.slrow .sv{font-size:13px;font-weight:600;min-width:65px;text-align:right;color:var(--tx)}
.wgrid{display:grid;gap:6px;margin-bottom:.75rem}
.wrow{display:grid;grid-template-columns:85px 1fr 58px 68px;gap:6px;align-items:center;padding:6px 9px;border-radius:var(--rs);border:.5px solid var(--bdr);background:var(--bg2)}
.wrow input{padding:5px 7px;font-size:13px;font-weight:600;border:.5px solid var(--bdr2);border-radius:var(--rs);background:var(--bg3);color:var(--tx);-moz-appearance:textfield;width:100%;text-align:right}
.wrow input::-webkit-inner-spin-button{-webkit-appearance:none}
.wml{font-size:12px;font-weight:500;color:var(--tx2)}
.wmv{font-size:11px;color:var(--tx3);text-align:right}
.gfrow{display:flex;align-items:center;gap:10px;margin-bottom:.6rem}
.gfrow label{font-size:13px;color:var(--tx2);min-width:120px;flex-shrink:0}
.gfrow .iw{flex:1;margin:0}
.gfrow .iw input{padding:9px 44px 9px 36px;font-size:15px}
.stbl{width:100%;border-collapse:collapse;font-size:11px;min-width:460px}
.stbl th{text-align:left;padding:6px 7px;font-size:9px;font-weight:700;color:var(--tx3);border-bottom:.5px solid var(--bdr2);white-space:nowrap;text-transform:uppercase;letter-spacing:.04em}
.stbl td{padding:8px 7px;border-bottom:.5px solid var(--bdr);color:var(--tx);vertical-align:middle;white-space:nowrap}
.stbl tr:last-child td{border-bottom:none}
.stbl tr:hover td{background:rgba(255,255,255,.03)}
.pill{display:inline-block;font-size:9px;padding:1px 5px;border-radius:9px;font-weight:700}
.p-up{background:var(--red-l);color:var(--red)}
.p-dn{background:var(--green-l);color:var(--green)}
.p-neu{background:var(--bg3);color:var(--tx3)}
.p-cap{background:var(--amber-l);color:var(--amber)}
.sblk{margin-bottom:.9rem}
.stit{font-size:11px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;margin:0 0 7px}
</style>
</head>
<body>

<div class="hdr">
  <div class="logo">⛽</div>
  <div>
    <h1>Gasolina Ecuador</h1>
    <p id="hdr-sub">Decreto Ejecutivo 308</p>
  </div>
</div>

<div class="wrap">

<div class="stbar">
  <span class="sdot loading" id="sdot"></span>
  <span id="stxt"><span class="spin"></span>Conectando al servidor...</span>
  <button class="rbtn" onclick="fetchFresh(true)">↻ Actualizar</button>
</div>

<div class="vigente-bar">
  <span class="vigente-lbl">📅 Precios oficiales ARCH vigentes:</span>
  <span class="vigente-per" id="periodo-lbl">—</span>
</div>

<div class="banner">
  <div class="bni"><p class="bnl">WTI</p><p class="bnv" id="bn-wti">—</p></div>
  <div class="bni"><p class="bnl">Tesoro 10a</p><p class="bnv" id="bn-rt">—</p></div>
  <div class="bni"><p class="bnl">Var. "a" próx.</p><p class="bnv" id="bn-a">—</p></div>
  <div class="bni"><p class="bnl">Actualizado</p><p class="bnv" id="bn-t">—</p></div>
</div>

<div class="tabs">
  <button class="tb on" onclick="nav('calc',this)">⛽ Calculadora</button>
  <button class="tb" onclick="nav('sim',this)">🔭 Simulador</button>
  <button class="tb" onclick="nav('mkt',this)">📊 Precios</button>
</div>

<!-- CALCULADORA -->
<div id="v-calc">
  <p class="sec">Selecciona el combustible</p>
  <div class="frow">
    <div class="fc sel" onclick="selF('extra',this)" id="fc-extra">
      <p class="fn">Extra / Eco País</p><p class="fs">85 RON</p>
      <p class="fp" id="fp-extra">—</p><p class="fu">/ galón</p>
      <span class="badge b-blue" id="fb-extra">Vigente</span>
    </div>
    <div class="fc" onclick="selF('diesel',this)" id="fc-diesel">
      <p class="fn">Diésel</p><p class="fs">regulado</p>
      <p class="fp" id="fp-diesel">—</p><p class="fu">/ galón</p>
      <span class="badge b-blue">Vigente</span>
    </div>
    <div class="fc" onclick="selF('super',this)" id="fc-super">
      <p class="fn">Super</p><p class="fs">>85 RON</p>
      <p class="fp" id="fp-super">—</p><p class="fu">/ galón</p>
      <span class="badge b-blue" id="fb-super">Vigente</span>
    </div>
  </div>

  <div class="mtog">
    <button class="mb on" id="mb-g" onclick="setM('g',this)">⛽ Galones → cuánto pago</button>
    <button class="mb" id="mb-u" onclick="setM('u',this)">$ Dólares → cuántos galones</button>
  </div>

  <div id="pg">
    <p class="sec">Cantidad de galones</p>
    <div class="iw">
      <span class="ipfx">⛽</span>
      <input type="number" id="ig" min="0.01" step="0.01" value="10" placeholder="Ej: 10" oninput="rc()">
      <span class="isfx">galones</span>
    </div>
    <div class="card">
      <p class="sec">Total a pagar</p>
      <p class="big" id="r-tot">—</p>
      <p class="rlbl" id="r-lg">—</p>
      <div class="sep"></div>
      <div class="cr"><span class="crl">Precio oficial ARCH</span><span class="crv" id="cg-p">—</span></div>
      <div class="cr"><span class="crl">Subtotal sin IVA</span><span class="crv" id="cg-s">—</span></div>
      <div class="cr"><span class="crl">IVA 15%</span><span class="crv" id="cg-i">—</span></div>
      <div class="cr"><span class="crl">📅 Vigente</span><span class="crv" id="cg-per" style="font-size:11px;color:var(--tx2)">—</span></div>
    </div>
  </div>

  <div id="pu" style="display:none">
    <p class="sec">Cantidad en dólares</p>
    <div class="iw">
      <span class="ipfx" style="font-size:18px;font-weight:700;color:var(--tx3)">$</span>
      <input type="number" id="iu" min="0.01" step="0.01" value="20" placeholder="Ej: 20" oninput="rc()">
      <span class="isfx">USD</span>
    </div>
    <div class="card">
      <p class="sec">Galones que obtienes</p>
      <p class="big" id="r-gal">—</p>
      <p class="rlbl" id="r-lu">—</p>
      <div class="sep"></div>
      <div class="cr"><span class="crl">Precio oficial ARCH</span><span class="crv" id="cu-p">—</span></div>
      <div class="cr"><span class="crl">Galones completos</span><span class="crv" id="cu-e">—</span></div>
      <div class="cr"><span class="crl">Vuelto</span><span class="crv" id="cu-v">—</span></div>
      <div class="cr"><span class="crl">📅 Vigente</span><span class="crv" id="cu-per" style="font-size:11px;color:var(--tx2)">—</span></div>
    </div>
  </div>
</div>

<!-- SIMULADOR -->
<div id="v-sim" style="display:none">
  <p class="sec">Combustibles a simular</p>
  <div class="sfsel">
    <label class="sfc act" id="sfc-extra"><input type="checkbox" id="chk-extra" checked onchange="togF('extra')"> Extra/Eco País</label>
    <label class="sfc" id="sfc-diesel"><input type="checkbox" id="chk-diesel" onchange="togF('diesel')"> Diésel</label>
    <label class="sfc" id="sfc-super"><input type="checkbox" id="chk-super" onchange="togF('super')"> Super</label>
  </div>
  <div class="slrow">
    <label>Meses a simular</label>
    <input type="range" id="nm" min="1" max="12" step="1" value="3" oninput="onNM()">
    <span class="sv" id="nm-lbl">3 meses</span>
  </div>
  <p class="sec">WTI esperado (USD/barril)</p>
  <div class="wgrid" id="wgrid"></div>
  <p style="font-size:11px;color:var(--tx3);margin:-.25rem 0 1rem">WTI actual: <span id="wti-now">—</span></p>
  <div class="sep"></div>
  <p class="sec">Galones por mes</p>
  <div id="ginps"></div>
  <p class="sec" style="margin-top:.75rem">Proyección mes a mes</p>
  <div class="card" style="padding:.75rem;overflow-x:auto">
    <table class="stbl"><thead id="sthead"></thead><tbody id="stbody"></tbody></table>
  </div>
  <div class="card"><p class="sec">Resumen</p><div id="ssum"></div></div>
</div>

<!-- PRECIOS -->
<div id="v-mkt" style="display:none">
  <p class="sec">Precios oficiales ARCH vigentes</p>
  <div class="frow">
    <div class="fc nc"><p class="fn">Extra/Eco País</p><p class="fs">85 RON · Art. 2.2</p><p class="fp" id="vp-e">—</p><p class="fu">/ gal con IVA</p><span class="badge b-blue" style="margin-top:6px">Oficial ARCH</span></div>
    <div class="fc nc"><p class="fn">Diésel</p><p class="fs">Art. 2.1</p><p class="fp" id="vp-d">—</p><p class="fu">/ gal con IVA</p><span class="badge b-blue" style="margin-top:6px">Oficial ARCH</span></div>
    <div class="fc nc"><p class="fn">Super</p><p class="fs">>85 RON</p><p class="fp" id="vp-s">—</p><p class="fu">/ gal con IVA</p><span class="badge b-blue" style="margin-top:6px">Oficial ARCH</span></div>
  </div>
  <div class="card">
    <p class="sec">Proyección próximo mes (estimada con WTI actual)</p>
    <div class="cr"><span class="crl">WTI hoy</span><span class="crv" id="vd-w">—</span></div>
    <div class="cr"><span class="crl">Tesoro EE.UU. 10 años</span><span class="crv" id="vd-r">—</span></div>
    <div class="cr"><span class="crl">Variación "a" estimada</span><span class="crv" id="vd-a">—</span></div>
    <div class="cr"><span class="crl">Extra próximo mes (est.)</span><span class="crv" id="vd-pe">—</span></div>
    <div class="cr"><span class="crl">Super próximo mes (est.)</span><span class="crv" id="vd-ps">—</span></div>
    <div class="cr"><span class="crl">Fuente datos</span><span class="crv" id="vd-src">—</span></div>
  </div>
  <p style="font-size:11px;color:var(--tx3);line-height:1.6;margin-top:.25rem">
    Los precios oficiales los publica la <strong style="color:var(--tx2)">ARCH</strong> el día 12 de cada mes y son vigentes hasta el día 11 del mes siguiente. La proyección es estimada según D.E. 308 con el WTI actual.
  </p>
</div>

</div>
</body>
</html>
<script>
// ═══════════════════════════════════════════════
// CONSTANTES D.E. 308
// ═══════════════════════════════════════════════
const IVA=0.15, MGC=0.1603125, PISO_PT=1.983166;
const MO=['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

// ═══════════════════════════════════════════════
// TABLA DE PRECIOS OFICIALES ARCH
// Vigentes del día 12 al 11 del mes siguiente
// ► Agregar nueva fila el día 12 de cada mes
// ═══════════════════════════════════════════════
const ARCH=[
  {d:'2026-03-12',h:'2026-04-11',e:2.890,di:2.828,s:3.620},
  {d:'2026-04-12',h:'2026-05-11',e:3.024,di:2.962,s:4.570},
  {d:'2026-05-12',h:'2026-06-11',e:3.164,di:3.103,s:4.810},
  // Agregar aquí el 12 de junio:
  // {d:'2026-06-12',h:'2026-07-11',e:X.XXX,di:X.XXX,s:X.XXX},
];

// Detecta el precio vigente según la fecha de HOY
function precioHoy(){
  const hoy=new Date().toISOString().slice(0,10);
  for(let i=ARCH.length-1;i>=0;i--){
    if(hoy>=ARCH[i].d && hoy<=ARCH[i].h) return ARCH[i];
  }
  // Si estamos antes del primer periodo, usar el primero
  if(new Date().toISOString().slice(0,10)<ARCH[0].d) return ARCH[0];
  // Si estamos después del último, usar el último
  return ARCH[ARCH.length-1];
}

function fmtFecha(s){
  const d=new Date(s+'T12:00:00');
  return d.getDate()+' '+['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'][d.getMonth()]+' '+d.getFullYear();
}

// Precio vigente HOY
const V=precioHoy();
const PERIODO=fmtFecha(V.d)+' – '+fmtFecha(V.h);
const SUPER_RATIO=V.s/V.e;

// Mes/año del periodo vigente (para simulador)
const _dv=new Date(V.d+'T12:00:00');
const CUR_M=_dv.getMonth();
const CUR_Y=_dv.getFullYear();
const PT_BASE=V.e/(1+IVA)-MGC;

// Precios por combustible
function priceOf(f){ return f==='extra'?V.e:f==='diesel'?V.di:V.s; }
function nameOf(f){ return f==='extra'?'Extra/Eco País':f==='diesel'?'Diésel':'Super'; }
function colOf(f){ return f==='extra'?'#3b82f6':f==='super'?'#8b5cf6':'#f59e0b'; }
function mLbl(m,y){ return MO[m]+' '+y; }

// ═══════════════════════════════════════════════
// MOTOR CÁLCULO D.E. 308 (para proyección)
// ═══════════════════════════════════════════════
function calcProyeccion(wti,rt,ptBase){
  const pm=wti/42+0.042, seg=(pm+0.058)*0.0005;
  const ppi=pm+0.058+seg+0.038, ppimg=ppi*(1+rt);
  const ar=(ppimg/ptBase-1)*100;
  let aa=ar>=5?5:(ar<=-10?-10:ar);
  let pn=ptBase*(1+aa/100);
  if(pn<PISO_PT)pn=PISO_PT;
  const e=(pn+MGC)*(1+IVA);
  return{extra:e,diesel:V.di,super:Math.max(e*SUPER_RATIO,e),pn,aa,ar};
}

// ═══════════════════════════════════════════════
// CACHÉ
// ═══════════════════════════════════════════════
const CK='ec_fuel_v5',TTL=30*60*1e3;
function lc(){try{const r=localStorage.getItem(CK);if(!r)return null;const c=JSON.parse(r);return Date.now()-c.ts<TTL?c:null;}catch{return null;}}
function sc(w,r){try{localStorage.setItem(CK,JSON.stringify({wti:w,rt:r,ts:Date.now()}));}catch{}}

// ═══════════════════════════════════════════════
// ESTADO
// ═══════════════════════════════════════════════
let CF='extra', CM='g';
let LW=103, LR=0.046, PROY=null;
let SWV=Array(12).fill(103), SF={extra:true,diesel:false,super:false}, SG={extra:10,diesel:10,super:10};
let fetching=false;

// ═══════════════════════════════════════════════
// FETCH DATOS DE MERCADO (Worker → fallback)
// ═══════════════════════════════════════════════
const API_URL='/api/market';

async function fetchFromWorker(){
  const r=await fetch(API_URL,{signal:AbortSignal.timeout(8000)});
  if(!r.ok)throw new Error('API '+r.status);
  const d=await r.json();
  if(d.error)throw new Error(d.error);
  // Si la API devuelve precios ARCH actualizados, actualizar la tabla local
  if(d.precios && d.precios.e && d.precios.di && d.precios.s){
    const p=d.precios;
    // Verificar si ya existe este periodo en ARCH
    const existe=ARCH.some(a=>a.d===p.d);
    if(!existe && p.d && p.h){
      ARCH.push({d:p.d,h:p.h,e:p.e,di:p.di,s:p.s});
      // Recalcular precio vigente con datos frescos
      Object.assign(V,{e:p.e,di:p.di,s:p.s,d:p.d,h:p.h});
      initPantalla();
    }
  }
  return d;
}
async function fetchWTI_fb(){
  const r=await fetch('https://query1.finance.yahoo.com/v8/finance/chart/CL=F?interval=1d&range=5d',{signal:AbortSignal.timeout(6000)});
  if(!r.ok)throw new Error();
  const d=await r.json();
  const a=d.chart.result[0].indicators.quote[0].close.filter(x=>x!=null);
  return +a[a.length-1];
}
async function fetchRt_fb(){
  const r=await fetch('https://api.allorigins.win/get?url='+encodeURIComponent('https://home.treasury.gov/resource-center/data-chart-center/interest-rates/pages/xml?data=daily_treasury_yield_curve&field_tdr_date_value=202605'),{signal:AbortSignal.timeout(7000)});
  const xml=(await r.json()).contents;
  const m=[...xml.matchAll(/BC_10YEAR[^>]*>([^<]+)</g)];
  if(!m.length)throw new Error();
  return parseFloat(m[m.length-1][1])/100;
}

async function fetchFresh(manual){
  if(fetching)return; fetching=true;
  const st=document.getElementById('stxt');
  st.innerHTML='<span class="spin"></span>'+(manual?'Actualizando...':'Actualizando en segundo plano...');
  document.getElementById('sdot').className='sdot loading';
  try{
    let wv,rv,src;
    try{
      const d=await fetchFromWorker();
      wv=d.wti||LW; rv=d.rt||LR; src='Worker propio ⚡';
    }catch{
      const[w,r]=await Promise.allSettled([fetchWTI_fb(),fetchRt_fb()]);
      wv=w.status==='fulfilled'&&w.value>0?w.value:LW;
      rv=r.status==='fulfilled'&&r.value>0?r.value:LR;
      src=w.status==='fulfilled'?'tiempo real':'estimado';
    }
    sc(wv,rv);
    applyMkt(wv,rv,src);
    document.getElementById('sdot').className='sdot live';
    st.textContent='WTI $'+wv.toFixed(2)+' · Tesoro '+(rv*100).toFixed(2)+'% · '+src;
  }catch{
    document.getElementById('sdot').className='sdot cerr';
    document.getElementById('stxt').textContent='Sin conexión · mostrando precios ARCH vigentes';
  }
  fetching=false;
}

// ═══════════════════════════════════════════════
// ACTUALIZAR PANTALLA CON DATOS DE MERCADO
// ═══════════════════════════════════════════════
function applyMkt(wti,rt,src){
  LW=wti; LR=rt;
  PROY=calcProyeccion(wti,rt,PT_BASE);
  const as=PROY.aa>=0?'+':'';

  // Banner (datos de mercado para proyección)
  document.getElementById('bn-wti').textContent='$'+wti.toFixed(2);
  document.getElementById('bn-rt').textContent=(rt*100).toFixed(2)+'%';
  document.getElementById('bn-a').textContent=as+PROY.aa.toFixed(2)+'%';
  document.getElementById('bn-t').textContent=new Date().toLocaleTimeString('es-EC',{hour:'2-digit',minute:'2-digit'});

  // Pestaña Precios — proyección
  document.getElementById('vd-w').textContent='$'+wti.toFixed(2)+'/bbl';
  document.getElementById('vd-r').textContent=(rt*100).toFixed(2)+'%';
  document.getElementById('vd-a').textContent=(PROY.ar>=0?'+':'')+PROY.ar.toFixed(2)+'% → '+as+PROY.aa.toFixed(2)+'%';
  document.getElementById('vd-pe').textContent='$'+PROY.extra.toFixed(3)+'/gal (est.)';
  document.getElementById('vd-ps').textContent='$'+PROY.super.toFixed(3)+'/gal (est.)';
  document.getElementById('vd-src').textContent=src;

  // Actualizar WTI en simulador
  document.getElementById('wti-now').textContent='$'+wti.toFixed(2)+'/bbl';
  SWV=Array(12).fill(+wti.toFixed(1));
  buildWG(); rSim(); rc();
}

// ═══════════════════════════════════════════════
// INIT PANTALLA (precios ARCH — sin red)
// ═══════════════════════════════════════════════
function initPantalla(){
  // Header
  document.getElementById('hdr-sub').textContent='Decreto Ejecutivo 308';
  document.getElementById('periodo-lbl').textContent=PERIODO;

  // Tarjetas — precios ARCH vigentes HOY
  document.getElementById('fp-extra').textContent='$'+V.e.toFixed(3);
  document.getElementById('fp-diesel').textContent='$'+V.di.toFixed(3);
  document.getElementById('fp-super').textContent='$'+V.s.toFixed(3);

  // Pestaña Precios
  document.getElementById('vp-e').textContent='$'+V.e.toFixed(3);
  document.getElementById('vp-d').textContent='$'+V.di.toFixed(3);
  document.getElementById('vp-s').textContent='$'+V.s.toFixed(3);

  rc();
}

// ═══════════════════════════════════════════════
// CALCULADORA — usa SIEMPRE precios ARCH vigentes
// ═══════════════════════════════════════════════
function rc(){
  const p=priceOf(CF);
  const siva=p/(1+IVA);
  if(CM==='g'){
    const g=parseFloat(document.getElementById('ig').value)||0;
    const tot=g*p, totSiva=g*siva, totIva=g*(p-siva);
    document.getElementById('r-tot').textContent='$'+tot.toFixed(2);
    document.getElementById('r-lg').textContent=g+' gal de '+nameOf(CF)+' × $'+p.toFixed(3)+'/gal';
    document.getElementById('cg-p').textContent='$'+p.toFixed(3)+'/gal';
    document.getElementById('cg-s').textContent='$'+totSiva.toFixed(2);
    document.getElementById('cg-i').textContent='$'+totIva.toFixed(2);
    document.getElementById('cg-per').textContent=PERIODO;
  }else{
    const usd=parseFloat(document.getElementById('iu').value)||0;
    const g=usd/p;
    document.getElementById('r-gal').textContent=g.toFixed(3)+' gal';
    document.getElementById('r-lu').textContent='$'+usd.toFixed(2)+' ÷ $'+p.toFixed(3)+'/gal';
    document.getElementById('cu-p').textContent='$'+p.toFixed(3)+'/gal';
    document.getElementById('cu-e').textContent=Math.floor(g)+' gal';
    document.getElementById('cu-v').textContent='$'+Math.max(0,usd-Math.floor(g)*p).toFixed(2);
    document.getElementById('cu-per').textContent=PERIODO;
  }
}

// ═══════════════════════════════════════════════
// SIMULADOR
// ═══════════════════════════════════════════════
function togF(f){
  const c=document.getElementById('chk-'+f);
  if(!c.checked&&Object.values(SF).filter(Boolean).length<=1){c.checked=true;return;}
  SF[f]=c.checked;
  document.getElementById('sfc-'+f).classList.toggle('act',c.checked);
  bGI(); rSim();
}
function bGI(){
  document.getElementById('ginps').innerHTML=Object.keys(SF).filter(f=>SF[f]).map(f=>`
    <div class="gfrow"><label>${nameOf(f)}</label>
    <div class="iw"><span class="ipfx" style="font-size:14px">⛽</span>
    <input type="number" id="sg-${f}" min="0.01" step="0.01" value="${SG[f]}" placeholder="Ej: 10" oninput="SG['${f}']=parseFloat(this.value)||0;rSim()">
    <span class="isfx">gal/mes</span></div></div>`).join('');
}
function onNM(){
  const n=+document.getElementById('nm').value||1;
  document.getElementById('nm-lbl').textContent=n+' mes'+(n>1?'es':'');
  buildWG(); rSim();
}
function buildWG(){
  const n=+document.getElementById('nm').value||1;
  let m=CUR_M+1,y=CUR_Y; if(m>11){m=0;y++;}
  const g=document.getElementById('wgrid'); g.innerHTML='';
  for(let i=0;i<n;i++){
    const mm=(m+i)%12,yy=y+Math.floor((m+i)/12),wv=SWV[i]??LW;
    const row=document.createElement('div'); row.className='wrow';
    row.innerHTML=`<span class="wml">${mLbl(mm,yy)}</span>
      <input type="number" min="40" max="180" step="0.5" value="${wv.toFixed(1)}" oninput="SWV[${i}]=parseFloat(this.value)||${LW.toFixed(1)};rSim()">
      <span class="wmv">USD/bbl</span>
      <span class="wmv" id="sep-${i}" style="font-weight:700;color:var(--tx)">—</span>`;
    g.appendChild(row);
  }
}
function rSim(){
  const n=+document.getElementById('nm').value||1;
  const rt=LR, act=Object.keys(SF).filter(f=>SF[f]);
  let pt=PT_BASE, m=CUR_M+1, y=CUR_Y; if(m>11){m=0;y++;}
  const rows=[],tots={},difs={},mx={},mn={};
  act.forEach(f=>{tots[f]=0;difs[f]=0;mx[f]=0;mn[f]=999;});
  for(let i=0;i<n;i++){
    const mm=(m+i)%12,yy=y+Math.floor((m+i)/12);
    const wv=SWV[i]??LW;
    const c=calcProyeccion(wv,rt,pt);
    const row={lbl:mLbl(mm,yy),wv,c,f:{}};
    act.forEach(f=>{
      const p=c[f],gs=(SG[f]||0)*p,df=gs-(SG[f]||0)*priceOf(f);
      row.f[f]={p,gs,df};
      tots[f]+=gs;difs[f]+=df;
      if(p>mx[f])mx[f]=p;if(p<mn[f])mn[f]=p;
    });
    rows.push(row); pt=c.pn;
    const ep=document.getElementById('sep-'+i);if(ep)ep.textContent='$'+c.extra.toFixed(3);
  }
  // Cabecera
  let th='<tr><th>Mes</th><th>WTI</th><th>Var."a"</th>';
  act.forEach(f=>{th+=`<th style="color:${colOf(f)}">${nameOf(f)}</th><th style="color:${colOf(f)}">Gasto</th><th style="color:${colOf(f)}">vs vigente</th>`;});
  document.getElementById('sthead').innerHTML=th+'</tr>';
  // Filas
  document.getElementById('stbody').innerHTML=rows.map(r=>{
    const a=r.c.aa,ar=r.c.ar;
    let pl=ar>=5?'<span class="pill p-cap">+5%</span>':ar<=-9.5?'<span class="pill p-dn">-10%</span>':a>.05?`<span class="pill p-up">+${a.toFixed(1)}%</span>`:a<-.05?`<span class="pill p-dn">${a.toFixed(1)}%</span>`:'<span class="pill p-neu">0%</span>';
    let c=`<td style="font-weight:600">${r.lbl}</td><td>$${r.wv.toFixed(0)}</td><td>${pl}</td>`;
    act.forEach(f=>{
      const fd=r.f[f],dc=fd.df>.005?'color:var(--red)':fd.df<-.005?'color:var(--green)':'color:var(--tx3)';
      c+=`<td style="font-weight:600">$${fd.p.toFixed(3)}</td><td>$${fd.gs.toFixed(2)}</td><td style="${dc}">${fd.df>=0?'+':'−'}$${Math.abs(fd.df).toFixed(2)}</td>`;
    });
    return '<tr>'+c+'</tr>';
  }).join('');
  // Resumen
  document.getElementById('ssum').innerHTML=act.map(f=>`
    <div class="sblk">
      <p class="stit" style="color:${colOf(f)}">${nameOf(f)}</p>
      <div class="bkg" style="grid-template-columns:repeat(3,1fr)">
        <div class="bk"><p class="bkl">Gasto total</p><p class="bkv">$${tots[f].toFixed(2)}</p></div>
        <div class="bk"><p class="bkl">Promedio/mes</p><p class="bkv">$${(tots[f]/n).toFixed(2)}</p></div>
        <div class="bk"><p class="bkl">Diferencia total</p><p class="bkv" style="${difs[f]>=0?'color:var(--red)':'color:var(--green)'}">${difs[f]>=0?'+':'−'}$${Math.abs(difs[f]).toFixed(2)}</p></div>
        <div class="bk"><p class="bkl">Precio más alto</p><p class="bkv">$${mx[f].toFixed(3)}</p></div>
        <div class="bk"><p class="bkl">Precio más bajo</p><p class="bkv">$${mn[f].toFixed(3)}</p></div>
        <div class="bk"><p class="bkl">Galones/mes</p><p class="bkv">${(SG[f]||0).toFixed(2)} gal</p></div>
      </div>
    </div>`).join('<hr style="border:none;border-top:.5px solid var(--bdr);margin:.5rem 0">');
}

// ═══════════════════════════════════════════════
// UI
// ═══════════════════════════════════════════════
function selF(f,el){CF=f;document.querySelectorAll('#v-calc .fc').forEach(c=>c.classList.remove('sel'));el.classList.add('sel');rc();}
function setM(m,btn){CM=m;document.getElementById('mb-g').classList.toggle('on',m==='g');document.getElementById('mb-u').classList.toggle('on',m==='u');document.getElementById('pg').style.display=m==='g'?'block':'none';document.getElementById('pu').style.display=m==='u'?'block':'none';rc();}
function nav(id,btn){['calc','sim','mkt'].forEach(v=>document.getElementById('v-'+v).style.display=v===id?'block':'none');document.querySelectorAll('.tb').forEach(b=>b.classList.remove('on'));btn.classList.add('on');}

// ═══════════════════════════════════════════════
// ARRANQUE
// ═══════════════════════════════════════════════
document.getElementById('nm-lbl').textContent='3 meses';
initPantalla();  // ← primero, con precios ARCH (instantáneo)
bGI(); buildWG(); rSim();

const cached=lc();
if(cached){
  applyMkt(cached.wti,cached.rt,'caché guardado');
  const age=Math.round((Date.now()-cached.ts)/60000);
  document.getElementById('sdot').className='sdot live';
  document.getElementById('stxt').textContent='Caché guardado (hace '+age+' min) · actualizando...';
  fetchFresh(false);
}else{
  document.getElementById('stxt').innerHTML='<span class="spin"></span>Obteniendo WTI y Tesoro...';
  fetchFresh(false);
}
setInterval(()=>fetchFresh(false),5*60*1e3);
</script>
